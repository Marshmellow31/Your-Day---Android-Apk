<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Splash screen theme — uses the windowSplashScreenBackground and
        core-splashscreen library to show a branded splash while the app initializes.
    -->
    <style name="Theme.YourDay" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.YourDay.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="postSplashScreenTheme">@style/Theme.YourDay</item>
    </style>
</resources>
