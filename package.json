{
  "name": "student-planner-pwa",
  "version": "1.0.0",
  "description": "Production-ready student planner PWA with Firebase and Vercel",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vercel --prod",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:all": "firebase deploy --only firestore:rules,functions && vercel --prod"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  },
  "dependencies": {
    "firebase-admin": "^13.7.0"
  }
}
